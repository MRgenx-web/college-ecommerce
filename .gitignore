# This is a two-app project (backend/ and frontend/), each with its own
# .gitignore. This root file is a safety net for top-level and OS/editor
# junk that isn't already covered by those.

# Dependencies / build output, wherever they appear
**/node_modules/
**/dist/
**/dist-ssr/
**/.vite/

# Environment variables
**/.env
**/.env.local
!**/.env.example

# SQLite database files
**/*.db
**/*.db-shm
**/*.db-wal

# Logs
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
